{
    "name": "nf-co.re",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build-cache": "npm run build-pipeline-json && npm run build-component-json",
        "build-pipeline-json": "node bin/pipelines.json.js",
        "build-component-json": "node bin/components.json.js",
        "check-api-catalog": "node bin/check-api-catalog.js",
        "update": "npx npm-check-updates --interactive --format group --workspaces",
        "test-all": "for dir in sites/*; do (cd $dir && npm run test); done"
    },
    "workspaces": [
        "sites/*"
    ],
    "dependencies": {
        "@astrojs/compiler-rs": "^0.3.1",
        "@astrojs/markdown-satteri": "^0.3.3",
        "@astrojs/mdx": "^7.0.2",
        "@astrojs/netlify": "^8.1.2",
        "@astrojs/partytown": "^2.1.7",
        "@astrojs/sitemap": "^3.7.3",
        "@astrojs/svelte": "^9.0.1",
        "@expressive-code/plugin-line-numbers": "^0.44.0",
        "@mashehu/astropub-md": "^3.0.0",
        "@rollup/plugin-yaml": "5.0.0",
        "astro": "^7.0.7",
        "astro-expressive-code": "^0.44.0",
        "astro-icon": "^1.1.5",
        "expressive-code": "^0.44.0",
        "github-slugger": "^2.0.0",
        "node-emoji": "^2.2.0",
        "remark": "^15.0.1",
        "satteri": "^0.9.5",
        "shiki": "^4.3.1",
        "unist-util-visit": "^5.1.0"
    },
    "devDependencies": {
        "@j178/prek": "^0.4.9",
        "@playwright/test": "^1.61.1",
        "prettier": "^3.9.5",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-svelte": "^4.1.1"
    }
}
