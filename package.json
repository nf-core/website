{
    "name": "nf-co.re",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build-cache": "npm run build-pipeline-json && npm run build-component-json && npm run build-params-json",
        "build-pipeline-json": "node bin/pipelines.json.js",
        "build-component-json": "node bin/components.json.js",
        "build-params-json": "node bin/params.json.js",
        "update": "npx npm-check-updates --interactive --format group --workspaces",
        "test-all": "for dir in sites/*; do (cd $dir && npm run test); done"
    },
    "workspaces": [
        "sites/*"
    ],
    "dependencies": {
        "@astrojs/compiler-rs": "^0.1.10",
        "remark": "^15.0.1",
        "unist-util-visit": "^5.1.0"
    },
    "devDependencies": {
        "@j178/prek": "^0.3.13",
        "prettier": "^3.8.3",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-svelte": "^3.5.1"
    }
}
