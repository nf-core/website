---
import PageLayout from "@layouts/PageLayout.astro";
import SidebarNav from "@components/sidebar/SidebarNav.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import type { SidebarEntry } from "@utils/types";
import { sanitizeNfCoreLabels, addEntriesToSection } from "@utils/functions";

export async function getStaticPaths() {
    return ["get-started", "running", "developing", "contributors", "specifications", "community", "nf-core-tools"].map(
        (subsection) => ({
            params: {
                subsection: subsection,
            },
        }),
    );
}

const { subsection } = Astro.params;

const subsectionDescriptions: Record<string, string> = {
    "get-started": "New to nf-core? Start here to learn the basics and run your first pipeline.",
    running: "Run and configure nf-core pipelines",
    developing: "Create and maintain nf-core pipelines, components, and configs",
    contributors: "Contribute to the nf-core community",
    specifications: "Technical specifications for nf-core pipelines, components, and test data",
    community: "Community resources and guidelines",
    "nf-core-tools": "Command-line tools and API for working with nf-core",
};

const docs = await getCollection("docs");

let sections: SidebarEntry[] = [
    {
        type: "group",
        id: "get-started",
        label: "Get started",
        entries: [],
        collapsed: true,
        icon: "octicon:play-16",
        weight: 1,
    },
    {
        type: "group",
        id: "running",
        label: "Running",
        entries: [],
        collapsed: true,
        icon: "octicon:rocket-16",
        weight: 2,
    },
    {
        type: "group",
        id: "developing",
        label: "Developing",
        entries: [],
        collapsed: true,
        icon: "mdi:hammer-wrench",
        weight: 3,
    },
    {
        type: "group",
        id: "contributors",
        label: "Contributing",
        entries: [],
        collapsed: true,
        icon: "octicon:git-pull-request-16",
        weight: 4,
    },
    {
        type: "group",
        id: "specifications",
        label: "Specifications",
        entries: [],
        collapsed: true,
        icon: "octicon:checklist-16",
        weight: 5,
    },
    {
        type: "group",
        id: "community",
        label: "Community",
        entries: [],
        collapsed: true,
        icon: "mdi:sprout",
        weight: 6,
    },
    {
        type: "group",
        id: "nf-core-tools",
        label: "nf-core/tools",
        entries: [],
        collapsed: true,
        icon: "octicon:tools-16",
        weight: 7,
    },
];

addEntriesToSection(sections, docs, Astro.url.pathname);

const sortEntries = (entries: SidebarEntry[]) => {
    entries.sort((a, b) => {
        if (a.weight && !b.weight) {
            return -1;
        }
        if (!a.weight && b.weight) {
            return 1;
        }
        if (a.weight && b.weight && a.weight !== b.weight) {
            return a.weight < b.weight ? -1 : 1;
        }
        return a.label.localeCompare(b.label);
    });
    entries.forEach((entry) => {
        if (entry.type === "group" && entry.entries) {
            sortEntries(entry.entries);
        }
    });
};

sections.forEach((section) => {
    if (section.type === "group") {
        sortEntries(section.entries);
    }
});

type SubpageLink = { label: string; href: string; subtitle?: string };

function getSubtitleForHref(href: string | undefined): string | undefined {
    if (!href) {
        return undefined;
    }
    const doc = docs.find((d) => "/docs/" + d.id.replace(/\.[^/.]+$/, "") === href);
    return doc?.data.subtitle;
}

function collectGroupPages(groupEntries: SidebarEntry[]): SubpageLink[] {
    const pages: SubpageLink[] = [];
    for (const entry of groupEntries) {
        if (entry.type === "link") {
            pages.push({
                label: sanitizeNfCoreLabels(entry.label),
                href: entry.href,
                subtitle: getSubtitleForHref(entry.href),
            });
        } else if (entry.type === "group" && entry.entries) {
            pages.push(...collectGroupPages(entry.entries));
        }
    }
    return pages;
}

function partitionEntries(entries: SidebarEntry[]): {
    directPages: SubpageLink[];
    nestedGroups: { heading: string; pages: SubpageLink[] }[];
} {
    const directPages: SubpageLink[] = [];
    const nestedGroups: { heading: string; pages: SubpageLink[] }[] = [];

    for (const item of entries) {
        if (item.type === "link") {
            directPages.push({
                label: sanitizeNfCoreLabels(item.label),
                href: item.href,
                subtitle: getSubtitleForHref(item.href),
            });
        } else if (item.type === "group" && item.entries) {
            nestedGroups.push({
                heading: sanitizeNfCoreLabels(item.label),
                pages: collectGroupPages(item.entries),
            });
        }
    }

    return { directPages, nestedGroups };
}

type PageSection =
    | { kind: "single"; sectionTitle: string; link: SubpageLink }
    | {
          kind: "group";
          sectionTitle: string;
          directPages: SubpageLink[];
          nestedGroups: { heading: string; pages: SubpageLink[] }[];
      };

const activeSubsection = sections.find((s) => s.id === subsection);
const pageSections: PageSection[] = [];
if (activeSubsection?.type === "group") {
    for (const section of activeSubsection.entries) {
        if (section.type === "link") {
            pageSections.push({
                kind: "single",
                sectionTitle: sanitizeNfCoreLabels(section.label),
                link: {
                    label: sanitizeNfCoreLabels(section.label),
                    href: section.href,
                    subtitle: getSubtitleForHref(section.href),
                },
            });
        } else if (section.type === "group" && section.entries) {
            const { directPages, nestedGroups } = partitionEntries(section.entries);
            pageSections.push({
                kind: "group",
                sectionTitle: sanitizeNfCoreLabels(section.label),
                directPages,
                nestedGroups,
            });
        }
    }
}

const title = activeSubsection?.type === "group" ? activeSubsection.label : "";
const subtitle = subsection ? subsectionDescriptions[subsection] : "";
const splitUrl = `${Astro.url.pathname}/`.replace(/^\/|\/$/g, "").split("/");
---

<PageLayout title={title} subtitle={subtitle} mainpage_container={false}>
    <div slot="header-top" class="d-none d-md-block">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                {
                    splitUrl.slice(0, -1).map((slug, i) => (
                        <>
                            <li class="breadcrumb-item">
                                <a class="text-white" href={"/" + splitUrl.slice(0, i + 1).join("/")}>
                                    {slug.replaceAll("_", " ").replace(/(^|\s)\S/g, (match) => match.toUpperCase())}
                                </a>
                            </li>
                            <Icon name="octicon:chevron-right-16" class={"mt-1"} />
                        </>
                    ))
                }
            </ol>
        </nav>
    </div>
    <div class="container-fluid main-content">
        <div class="row">
            <div class="col-12 col-xl-8 order-2 doc-subsection-masonry">
                {
                    pageSections.map((block) => (
                        <div class="section-block mb-2">
                            <h2 class="section-heading mb-2">{block.sectionTitle}</h2>
                            {block.kind === "single" ? (
                                <ul class="doc-subpage-list list-unstyled mb-0 border-start border-2 ps-3 ms-2">
                                    <li class="doc-subpage-item mb-2">
                                        <a
                                            href={block.link.href}
                                            class="link-offset-2 fw-semibold text-decoration-none"
                                        >
                                            {block.link.label}
                                        </a>
                                        {block.link.subtitle && (
                                            <div class="doc-subpage-subtitle text-secondary small mt-0">
                                                {block.link.subtitle}
                                            </div>
                                        )}
                                    </li>
                                </ul>
                            ) : (
                                <div class="section-content">
                                    {block.directPages.length > 0 && (
                                        <ul class="doc-subpage-list list-unstyled mb-0 border-start border-2 ps-3 ms-2">
                                            {block.directPages.map((page) => (
                                                <li class="doc-subpage-item mb-2">
                                                    <a
                                                        href={page.href}
                                                        class="link-offset-2 fw-semibold text-decoration-none"
                                                    >
                                                        {page.label}
                                                    </a>
                                                    {page.subtitle && (
                                                        <div class="doc-subpage-subtitle text-secondary small mt-0 mb-2">
                                                            {page.subtitle}
                                                        </div>
                                                    )}
                                                </li>
                                            ))}
                                        </ul>
                                    )}
                                    {block.nestedGroups.length > 0 && (
                                        <div
                                            class:list={
                                                block.directPages.length > 0
                                                    ? ["doc-subpage-nested-groups", "mt-4"]
                                                    : undefined
                                            }
                                        >
                                            {block.nestedGroups.map((group) => (
                                                <>
                                                    <h3 class="subsection-heading mb-1">{group.heading}</h3>
                                                    <div class="nested-content">
                                                        <ul class="doc-subpage-list list-unstyled mb-0 border-start border-2 ps-3 ms-2">
                                                            {group.pages.map((page) => (
                                                                <li class="doc-subpage-item mb-3">
                                                                    <a
                                                                        href={page.href}
                                                                        class="link-offset-2 fw-semibold text-decoration-none"
                                                                    >
                                                                        {page.label}
                                                                    </a>
                                                                    {page.subtitle && (
                                                                        <div class="doc-subpage-subtitle text-secondary small mt-0">
                                                                            {page.subtitle}
                                                                        </div>
                                                                    )}
                                                                </li>
                                                            ))}
                                                        </ul>
                                                    </div>
                                                </>
                                            ))}
                                        </div>
                                    )}
                                </div>
                            )}
                        </div>
                    ))
                }
            </div>

            <div class="col-12 col-xl-3 sticky-top-under d-none d-xl-inline sidebar-left order-1">
                <SidebarNav items={sections} />
            </div>
        </div>
    </div>
</PageLayout>
<style is:global>
    .doc-subsection-masonry {
        column-count: 1;
        column-gap: var(--bs-gutter-x, 1.5rem);
    }

    @media (min-width: 992px) {
        .doc-subsection-masonry {
            column-count: 2;
        }
    }

    .doc-subsection-masonry .section-block {
        break-inside: avoid;
        page-break-inside: avoid;
        display: inline-block;
        width: 100%;
        vertical-align: top;
    }

    .doc-subpage-list .doc-subpage-item a:hover {
        text-decoration: underline !important;
    }

    .doc-subpage-subtitle {
        max-width: 42rem;
        text-wrap: pretty;
    }
</style>
