---
import ListingLayout from "@layouts/ListingLayout.astro";
import ComponentListing from "@components/component/ComponentListing.svelte";
import { renderMarkdown } from "@root/bin/satteri/markdownConfig.ts";

import components from "@public/components.json";

const modules = await Promise.all(
    components.modules.map(async (module) => {
        if (!module.meta.description) return module;
        const { html } = await renderMarkdown(module.meta.description);
        return { ...module, meta: { ...module.meta, description_rendered: html } };
    }),
);

const title = "nf-core/modules";
const description = "Browse the " + modules.length + " modules that are currently available as part of nf-core.";
---

<ListingLayout
    title={title}
    description={description}
    filter={[]}
    sortBy={["Name", "# Pipeline integrations"]}
    displayStyle={[
        { name: "grid", icon: "fa-regular fa-grid-2" },
        { name: "table", icon: "fa-regular fa-bars" },
    ]}
    viewTransitions={true}
>
    <ComponentListing components={modules} slot="listing-components" client:load />
</ListingLayout>
