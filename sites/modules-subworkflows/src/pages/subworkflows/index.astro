---
import ListingLayout from "@layouts/ListingLayout.astro";
import ComponentListing from "@components/component/ComponentListing.svelte";
import { renderMarkdown } from "@root/bin/satteri/markdownConfig.ts";

import components from "@public/components.json";

const subworkflows = await Promise.all(
    components.subworkflows.map(async (subworkflow) => {
        if (!subworkflow.meta.description) return subworkflow;
        const { html } = await renderMarkdown(subworkflow.meta.description);
        return { ...subworkflow, meta: { ...subworkflow.meta, description_rendered: html } };
    }),
);

const title = "nf-core/subworkflows";
const description =
    "Browse the " + subworkflows.length + " subworkflows that are currently available as part of nf-core.";
---

<ListingLayout
    title={title}
    description={description}
    filter={[]}
    sortBy={["Name", "# Pipeline integrations"]}
    searchExamples={[
        { query: "k:STR", label: "keywords" },
        { query: "n:samtools", label: "name" },
        { query: "d:cluster", label: "description" },
        { query: 'k:"STR"', label: "exact keyword" },
    ]}
    displayStyle={[
        { name: "grid", icon: "fa-regular fa-grid-2" },
        { name: "table", icon: "fa-regular fa-bars" },
    ]}
    viewTransitions={true}
>
    <ComponentListing components={subworkflows} slot="listing-components" client:load />
</ListingLayout>
