---
import PageLayout from "@layouts/PageLayout.astro";
import { getCollection } from "astro:content";
import pipelines_json from "@public/pipelines.json";
import {
    getNewsletterMonths,
    getBlogPostsForMonth,
    getBlogPostsForPreviousMonths,
    getPipelineReleasesForMonth,
    getNewPipelines,
    getEventsForMonth,
    getFutureEvents,
    getMonthName,
    fetchAllProposals,
    getProposalsForMonth,
} from "@utils/newsletter";
import type { NewsletterMonth } from "@utils/newsletter";
import newsletterLogoLight from "@assets/images/logo/nf-core-newsletter-lightbg.png";
import newsletterLogoDark from "@assets/images/logo/nf-core-newsletter-darkbg.png";

export async function getStaticPaths() {
    let blogPosts = await getCollection("blog");
    blogPosts = blogPosts.filter((post) => new Date(post.data.pubDate) < new Date());

    let events = await getCollection("events");
    events = events.filter((e) => e.id.split("/").length === 2);

    const pipelines = pipelines_json.remote_workflows;
    const months = getNewsletterMonths(blogPosts, events, pipelines);

    // Fetch all proposals once for all pages
    let allProposals: any[] = [];
    try {
        allProposals = await fetchAllProposals();
    } catch (e) {
        console.warn("Could not fetch proposals:", e);
    }

    return months.map(({ year, month }, index) => ({
        params: {
            year: String(year),
            month: String(month).padStart(2, "0"),
        },
        props: {
            year,
            month,
            allMonths: months,
            allProposals,
            prevMonth: months[index + 1] || null,
            nextMonth: months[index - 1] || null,
        },
    }));
}

const { year, month, allMonths, allProposals, prevMonth, nextMonth } = Astro.props as {
    year: number;
    month: number;
    allMonths: NewsletterMonth[];
    allProposals: any[];
    prevMonth: NewsletterMonth | null;
    nextMonth: NewsletterMonth | null;
};

const monthName = getMonthName(month);
const baseUrl = "https://nf-co.re";

// Fetch all data
let blogPosts = await getCollection("blog");
blogPosts = blogPosts.filter((post) => new Date(post.data.pubDate) < new Date());

let events = await getCollection("events");
events = events.filter((e) => e.id.split("/").length === 2);

const pipelines = pipelines_json.remote_workflows;

const thisMonthBlogPosts = getBlogPostsForMonth(blogPosts, year, month);
const olderBlogPosts = getBlogPostsForPreviousMonths(blogPosts, year, month, 2);
const releases = getPipelineReleasesForMonth(pipelines, year, month);
const firstReleases = releases.filter((r) => r.isFirstRelease);
const otherReleases = releases.filter((r) => !r.isFirstRelease);
const newPipelines = getNewPipelines(pipelines, year, month);
const thisMonthEvents = getEventsForMonth(events, year, month);
const upcomingEvents = getFutureEvents(events, year, month, 2);

// Filter proposals for this month
const proposals = getProposalsForMonth(allProposals, year, month);

// Event type color mapping
const eventTypeColor: Record<string, string> = {
    bytesize: "#22ae63",
    hackathon: "#0d6efd",
    talk: "#0dcaf0",
    training: "#ffc107",
};
const eventTypeLabel: Record<string, string> = {
    bytesize: "Bytesize",
    hackathon: "Hackathon",
    talk: "Talk",
    training: "Training",
};

function formatDate(date: Date): string {
    return new Date(date).toLocaleDateString("en-GB", {
        day: "numeric",
        month: "short",
        year: "numeric",
    });
}

function monthUrl(m: NewsletterMonth): string {
    return `/newsletter/${m.year}/${String(m.month).padStart(2, "0")}`;
}

function blogUrl(postId: string): string {
    return `${baseUrl}/blog/${postId.replace(/\.[^/.]+$/, "")}`;
}

function eventUrl(eventId: string): string {
    return `${baseUrl}/events/${eventId.replace(/\.[^/.]+$/, "")}`;
}

function pipelineUrl(name: string): string {
    return `${baseUrl}/${name}`;
}
---

<PageLayout
    title={`Newsletter - ${monthName} ${year}`}
    subtitle={`nf-core community newsletter for ${monthName} ${year}`}
    mainpage_container={true}
    subfooter={false}
>
    {/* ===== NAVIGATION (excluded from email) ===== */}
    <nav class="mb-4 newsletter-nav">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            {
                prevMonth ? (
                    <a href={monthUrl(prevMonth)} class="btn btn-outline-secondary btn-sm">
                        &larr; {getMonthName(prevMonth.month)} {prevMonth.year}
                    </a>
                ) : (
                    <span />
                )
            }

            <select id="newsletter-month-select" class="form-select form-select-sm w-auto">
                {
                    allMonths.map((m) => (
                        <option value={monthUrl(m)} selected={m.year === year && m.month === month}>
                            {getMonthName(m.month)} {m.year}
                        </option>
                    ))
                }
            </select>

            {
                nextMonth ? (
                    <a href={monthUrl(nextMonth)} class="btn btn-outline-secondary btn-sm">
                        {getMonthName(nextMonth.month)} {nextMonth.year} &rarr;
                    </a>
                ) : (
                    <span />
                )
            }
        </div>
    </nav>

    {/* ===== NEWSLETTER CONTENT (extractable for email) ===== */}
    <div id="newsletter-content">
        {/* ----- HEADER WITH LOGO ----- */}
        <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
            <tr>
                <td style="text-align: center; padding: 20px 0;">
                    <img
                        class="nl-logo-light"
                        src={newsletterLogoLight.src}
                        alt="nf-core newsletter"
                        width="400"
                        style="max-width: 100%; height: auto; display: block; margin: 0 auto;"
                    />
                    <img
                        class="nl-logo-dark"
                        src={newsletterLogoDark.src}
                        alt="nf-core newsletter"
                        width="400"
                        style="max-width: 100%; height: auto; display: none; margin: 0 auto;"
                    />
                    <p class="nl-muted" style="margin: 12px 0 0; font-size: 18px; color: #666666;">
                        {monthName}
                        {year}
                    </p>
                </td>
            </tr>
        </table>

        {/* ----- UPCOMING EVENTS (primary) ----- */}
        {
            upcomingEvents.length > 0 && (
                <>
                    <h2 style="font-size: 22px; color: #22ae63; border-bottom: 2px solid #22ae63; padding-bottom: 8px; margin-top: 32px;">
                        Upcoming Events
                    </h2>
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
                        {upcomingEvents.map((event) => (
                            <tr>
                                <td style="padding: 12px 0; border-bottom: 1px solid #eeeeee; vertical-align: top;">
                                    <a
                                        href={eventUrl(event.id)}
                                        style="color: #333333; text-decoration: none; font-weight: 600; font-size: 16px;"
                                    >
                                        {event.data.title}
                                    </a>
                                    <br />
                                    <span class="nl-muted" style="font-size: 13px; color: #666666;">
                                        {formatDate(event.data.start)}
                                        {event.data.start.toDateString() !== event.data.end.toDateString() && (
                                            <> &ndash; {formatDate(event.data.end)}</>
                                        )}
                                    </span>
                                    <span
                                        style={`display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 3px; margin-left: 8px; color: #ffffff; background-color: ${eventTypeColor[event.data.type] || "#6c757d"};`}
                                    >
                                        {eventTypeLabel[event.data.type] || event.data.type}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </table>
                </>
            )
        }

        {/* ----- EVENTS THIS MONTH (secondary, smaller) ----- */}
        {
            thisMonthEvents.length > 0 && (
                <>
                    <h3 style="font-size: 18px; color: #666666; margin-top: 24px;">Events This Month</h3>
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
                        {thisMonthEvents.map((event) => (
                            <tr>
                                <td style="padding: 8px 0; border-bottom: 1px solid #f0f0f0; vertical-align: top;">
                                    <a
                                        href={eventUrl(event.id)}
                                        style="color: #555555; text-decoration: none; font-weight: 600; font-size: 14px;"
                                    >
                                        {event.data.title}
                                    </a>
                                    <span class="nl-muted" style="font-size: 12px; color: #888888; margin-left: 8px;">
                                        {formatDate(event.data.start)}
                                        {event.data.start.toDateString() !== event.data.end.toDateString() && (
                                            <> &ndash; {formatDate(event.data.end)}</>
                                        )}
                                    </span>
                                    <span
                                        style={`display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 3px; margin-left: 8px; color: #ffffff; background-color: ${eventTypeColor[event.data.type] || "#6c757d"};`}
                                    >
                                        {eventTypeLabel[event.data.type] || event.data.type}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </table>
                </>
            )
        }

        {/* ----- BLOG POSTS THIS MONTH ----- */}
        {
            thisMonthBlogPosts.length > 0 && (
                <>
                    <h2 style="font-size: 22px; color: #22ae63; border-bottom: 2px solid #22ae63; padding-bottom: 8px; margin-top: 32px;">
                        Blog Posts
                    </h2>
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
                        {thisMonthBlogPosts.map((post) => (
                            <tr>
                                <td style="padding: 12px 0; border-bottom: 1px solid #eeeeee;">
                                    <a
                                        href={blogUrl(post.id)}
                                        style="color: #333333; text-decoration: none; font-weight: 600; font-size: 16px;"
                                    >
                                        {post.data.title}
                                    </a>
                                    <br />
                                    <span class="nl-muted" style="font-size: 14px; color: #555555;">
                                        {post.data.subtitle}
                                    </span>
                                    <br />
                                    <span class="nl-muted" style="font-size: 13px; color: #888888;">
                                        {formatDate(post.data.pubDate)} &middot; by {post.data.authors.join(", ")}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </table>
                </>
            )
        }

        {/* ----- IN CASE YOU MISSED IT ----- */}
        {
            olderBlogPosts.length > 0 && (
                <>
                    <h3 style="font-size: 18px; color: #666666; margin-top: 24px;">In Case You Missed It</h3>
                    <p class="nl-muted" style="font-size: 13px; color: #888888; margin-bottom: 12px;">
                        Blog posts from the past couple of months.
                    </p>
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
                        {olderBlogPosts.map((post) => (
                            <tr>
                                <td style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
                                    <a
                                        href={blogUrl(post.id)}
                                        style="color: #555555; text-decoration: none; font-weight: 600; font-size: 14px;"
                                    >
                                        {post.data.title}
                                    </a>
                                    <span class="nl-muted" style="font-size: 12px; color: #999999; margin-left: 8px;">
                                        {formatDate(post.data.pubDate)}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </table>
                </>
            )
        }

        {/* ----- FIRST PIPELINE RELEASES ----- */}
        {
            firstReleases.length > 0 && (
                <>
                    <h2 style="font-size: 22px; color: #22ae63; border-bottom: 2px solid #22ae63; padding-bottom: 8px; margin-top: 32px;">
                        New Pipeline First Releases! &#127881;
                    </h2>
                    <p class="nl-muted" style="font-size: 14px; color: #666666; margin-bottom: 12px;">
                        These pipelines published their very first release this month.
                    </p>
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
                        {firstReleases.map((release) => (
                            <tr>
                                <td style="padding: 12px 0; border-bottom: 1px solid #eeeeee;">
                                    <a
                                        href={pipelineUrl(release.pipelineName)}
                                        style="color: #22ae63; text-decoration: none; font-weight: 700; font-size: 16px;"
                                    >
                                        nf-core/{release.pipelineName}
                                    </a>
                                    {release.tagNames.map((tag) => (
                                        <span style="display: inline-block; font-size: 12px; padding: 2px 8px; border-radius: 3px; margin-left: 8px; color: #ffffff; background-color: #22ae63;">
                                            v{tag}
                                        </span>
                                    ))}
                                    <br />
                                    <span class="nl-muted" style="font-size: 14px; color: #555555;">
                                        {release.description}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </table>
                </>
            )
        }

        {/* ----- OTHER PIPELINE RELEASES ----- */}
        {
            otherReleases.length > 0 && (
                <>
                    <h2 style="font-size: 22px; color: #22ae63; border-bottom: 2px solid #22ae63; padding-bottom: 8px; margin-top: 32px;">
                        Pipeline Releases
                    </h2>
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
                        {otherReleases.map((release) => (
                            <tr>
                                <td style="padding: 10px 0; border-bottom: 1px solid #eeeeee;">
                                    <a
                                        href={pipelineUrl(release.pipelineName)}
                                        style="color: #333333; text-decoration: none; font-weight: 600; font-size: 15px;"
                                    >
                                        nf-core/{release.pipelineName}
                                    </a>
                                    {release.tagNames.map((tag) => (
                                        <span style="display: inline-block; font-size: 12px; padding: 2px 8px; border-radius: 3px; margin-left: 8px; color: #ffffff; background-color: #6c757d;">
                                            v{tag}
                                        </span>
                                    ))}
                                    <span class="nl-muted" style="font-size: 13px; color: #888888; margin-left: 8px;">
                                        {formatDate(new Date(release.publishedAt))}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </table>
                </>
            )
        }

        {/* ----- NEW PIPELINES & PROPOSALS ----- */}
        {
            (newPipelines.length > 0 || proposals.length > 0) && (
                <>
                    <h2 style="font-size: 22px; color: #22ae63; border-bottom: 2px solid #22ae63; padding-bottom: 8px; margin-top: 32px;">
                        New Pipelines &amp; Proposals
                    </h2>
                </>
            )
        }

        {
            newPipelines.length > 0 && (
                <>
                    <h3 style="font-size: 18px; color: #333333; margin-top: 16px;">New Pipeline Repositories</h3>
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
                        {newPipelines.map((p) => (
                            <tr>
                                <td style="padding: 10px 0; border-bottom: 1px solid #eeeeee;">
                                    <a
                                        href={pipelineUrl(p.name)}
                                        style="color: #333333; text-decoration: none; font-weight: 600; font-size: 15px;"
                                    >
                                        nf-core/{p.name}
                                    </a>
                                    {p.isDevOnly && (
                                        <span style="display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 3px; margin-left: 8px; color: #856404; background-color: #fff3cd;">
                                            In Development
                                        </span>
                                    )}
                                    <br />
                                    <span class="nl-muted" style="font-size: 14px; color: #555555;">
                                        {p.description}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </table>
                </>
            )
        }

        {
            proposals.length > 0 && (
                <>
                    <h3 style="font-size: 18px; color: #333333; margin-top: 16px;">Pipeline Proposals</h3>
                    <p class="nl-muted" style="font-size: 13px; color: #888888; margin-bottom: 12px;">
                        New proposals and approvals from{" "}
                        <a href="https://github.com/nf-core/proposals/issues" style="color: #22ae63;">
                            nf-core/proposals
                        </a>
                        .
                    </p>
                    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
                        {proposals.map((p) => (
                            <tr>
                                <td style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
                                    <a
                                        href={p.url}
                                        style="color: #333333; text-decoration: none; font-weight: 600; font-size: 14px;"
                                    >
                                        {p.title}
                                    </a>
                                    <span class="nl-muted" style="font-size: 12px; color: #999999; margin-left: 8px;">
                                        #{p.number}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </table>
                </>
            )
        }

        {/* ----- FOOTER ----- */}
        <table width="100%" cellpadding="0" cellspacing="0" style="margin-top: 32px; border-top: 2px solid #eeeeee;">
            <tr>
                <td style="text-align: center; padding: 24px 0;">
                    <p class="nl-muted" style="font-size: 14px; color: #666666; margin: 0;">
                        This newsletter is brought to you by the <a
                            href="https://nf-co.re"
                            style="color: #22ae63; text-decoration: none; font-weight: 600;">nf-core</a
                        > community.
                    </p>
                    <p class="nl-muted" style="font-size: 13px; color: #999999; margin: 8px 0 0;">
                        <a href="https://nf-co.re/join" style="color: #22ae63;">Join us</a> &middot;
                        <a href="https://nf-co.re/blog" style="color: #22ae63;">Blog</a> &middot;
                        <a href="https://nf-co.re/events" style="color: #22ae63;">Events</a> &middot;
                        <a href="https://github.com/nf-core" style="color: #22ae63;">GitHub</a>
                    </p>
                </td>
            </tr>
        </table>
    </div>
</PageLayout>

<script>
    const select = document.getElementById("newsletter-month-select") as HTMLSelectElement;
    if (select) {
        select.addEventListener("change", () => {
            window.location.href = select.value;
        });
    }
</script>

<style lang="scss">
    .newsletter-nav {
        border-bottom: 1px solid var(--bs-border-color);
        padding-bottom: 1rem;
    }
    #newsletter-content {
        max-width: 600px;
        margin: 0 auto;
        padding: 16px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        /* Light mode base */
        background-color: #ffffff;
        color: #333333;
        border-radius: 8px;
    }
    #newsletter-content table {
        border-collapse: collapse;
    }
    #newsletter-content a:hover {
        text-decoration: underline !important;
    }

    /* Web dark mode: matches nf-core site theme toggle (data-bs-theme).
     * Needs !important to beat inline styles on email-friendly elements. */
    :global([data-bs-theme="dark"]) #newsletter-content {
        background-color: #1e1e2e !important;
        color: #e0e0e0 !important;
    }
    :global([data-bs-theme="dark"]) :global(.nl-logo-light) {
        display: none !important;
    }
    :global([data-bs-theme="dark"]) :global(.nl-logo-dark) {
        display: block !important;
    }
    :global([data-bs-theme="dark"]) #newsletter-content h2 {
        color: #4ade80 !important;
        border-bottom-color: #4ade80 !important;
    }
    :global([data-bs-theme="dark"]) #newsletter-content h3 {
        color: #cccccc !important;
    }
    :global([data-bs-theme="dark"]) #newsletter-content a {
        color: #4ade80 !important;
    }
    :global([data-bs-theme="dark"]) #newsletter-content :global(.nl-muted) {
        color: #aaaaaa !important;
    }
    :global([data-bs-theme="dark"]) #newsletter-content td {
        border-bottom-color: #333344 !important;
    }

    /*
     * Email dark mode: Apple Mail, Outlook Mac use prefers-color-scheme.
     * Outlook iOS/Android use [data-ogsc].
     * These only matter when the HTML is extracted and sent as email,
     * not on the website (where data-bs-theme handles it above).
     */
    @media (prefers-color-scheme: dark) {
        #newsletter-content {
            background-color: #1e1e2e !important;
            color: #e0e0e0 !important;
        }
        #newsletter-content .nl-logo-light {
            display: none !important;
        }
        #newsletter-content .nl-logo-dark {
            display: block !important;
        }
        #newsletter-content h2 {
            color: #4ade80 !important;
            border-bottom-color: #4ade80 !important;
        }
        #newsletter-content h3 {
            color: #cccccc !important;
        }
        #newsletter-content a {
            color: #4ade80 !important;
        }
        #newsletter-content .nl-muted {
            color: #aaaaaa !important;
        }
        #newsletter-content td {
            border-bottom-color: #333344 !important;
        }
    }

    [data-ogsc] #newsletter-content {
        background-color: #1e1e2e !important;
        color: #e0e0e0 !important;
    }
    [data-ogsc] #newsletter-content .nl-logo-light {
        display: none !important;
    }
    [data-ogsc] #newsletter-content .nl-logo-dark {
        display: block !important;
    }
    [data-ogsc] #newsletter-content h2 {
        color: #4ade80 !important;
        border-bottom-color: #4ade80 !important;
    }
    [data-ogsc] #newsletter-content h3 {
        color: #cccccc !important;
    }
    [data-ogsc] #newsletter-content a {
        color: #4ade80 !important;
    }
    [data-ogsc] #newsletter-content .nl-muted {
        color: #aaaaaa !important;
    }
    [data-ogsc] #newsletter-content td {
        border-bottom-color: #333344 !important;
    }
</style>
