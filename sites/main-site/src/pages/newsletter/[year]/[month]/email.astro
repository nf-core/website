---
import { getCollection } from "astro:content";
import pipelines_json from "@public/pipelines.json";
import { getNewsletterStaticPaths, getMonthName } from "@utils/newsletter";
import { getNewsletterContentData } from "@utils/newsletter-content";
import NewsletterLayout from "@layouts/NewsletterLayout.astro";

const images = import.meta.glob("/src/assets/**");

export async function getStaticPaths() {
    return getNewsletterStaticPaths(getCollection, pipelines_json.remote_workflows);
}

const { year, month, allProposals } = Astro.props as {
    year: number;
    month: number;
    allProposals: any[];
};

const pipelines = pipelines_json.remote_workflows;
const monthName = getMonthName(month);
const contentData = await getNewsletterContentData(getCollection, pipelines, year, month, allProposals, images);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>nf-core Newsletter - {monthName} {year}</title>
        <!-- is:inline keeps this verbatim + inline + unscoped: email clients drop
             external stylesheets, and Astro scoping would stop the responsive
             rules from matching the NewsletterContent elements. -->
        <style is:inline>
            body {
                margin: 0;
                padding: 20px;
                background-color: #f5f5f5;
                font-family: system-ui, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            }
            @media (prefers-color-scheme: dark) {
                body {
                    background-color: #121212;
                }
            }
            @media screen and (max-width: 600px) {
                #newsletter-content .nl-col,
                #newsletter-content .nl-blog-text,
                #newsletter-content .nl-blog-img {
                    max-width: 100% !important;
                    display: block !important;
                }
            }
        </style>
    </head>
    <body style="margin: 0; padding: 0;">
        <NewsletterLayout data={contentData} email={true} />
    </body>
</html>
