---
import PageLayout from "@layouts/PageLayout.astro";
import NewsletterSignup from "@components/newsletter/NewsletterSignup.astro";
---

<PageLayout
    title="Subscribe to the nf-core newsletter"
    subtitle="Monthly community news, pipeline releases, and events — straight to your inbox"
    mainpage_container={true}
    subfooter={false}
>
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-secondary mb-4">
                <div class="card-body p-4">
                    <NewsletterSignup compact={true} />
                </div>
            </div>

            <h2 class="h4">What you'll get</h2>
            <ul>
                <li>A round-up of new blog posts and community highlights.</li>
                <li>New pipeline releases and first releases.</li>
                <li>Upcoming events, talks, and hackathons.</li>
                <li>One email a month — nothing more.</li>
            </ul>

            <h2 class="h4 mt-4">How it works</h2>
            <p>
                We use a double opt-in: after you enter your address we'll email you a confirmation link, and you'll
                only be added to the list once you click it. Every newsletter includes a one-click unsubscribe link, so
                you can leave at any time.
            </p>

            <h2 class="h4 mt-4">Privacy</h2>
            <p>
                We store only your email address and the date you subscribed, in order to send you the newsletter.
                Contacts and delivery are managed with Amazon SES in the EU (eu-west-1). We never share your address,
                and you can unsubscribe whenever you like.
            </p>

            <p class="mt-4">
                <a href="/newsletter">← Browse past newsletters</a>
            </p>
        </div>
    </div>
</PageLayout>
