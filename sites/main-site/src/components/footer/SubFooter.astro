---
import BuildTimestamp from "@components/footer/BuildTimestamp.svelte";

const { md_github_url } = Astro.props;

const buildTimestamp = new Date().toISOString();
---

<footer class="subfooter bg-body-tertiary py-3">
    <div class="container text-center">
        {
            md_github_url && (
                <div class="row align-items-center">
                    <div class="col" />
                    <div class="col-auto">
                        <a href={md_github_url}>
                            <i class="fab fa-github" />
                            See the source code for this page
                        </a>
                    </div>
                    <div class="col text-secondary small d-none d-md-inline text-end">
                        <BuildTimestamp timestamp={buildTimestamp} client:idle />
                    </div>
                </div>
            )
        }
        <slot />
    </div>
</footer>
